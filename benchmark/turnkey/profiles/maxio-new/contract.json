{
  "//": "Maxio Advanced Billing wire contract for the maxio-new-integration (SDK-based). Provider shapes",
  "//2": "(snake_case, envelopes, ids) are authored from the Maxio provider contract, NOT the integration",
  "//3": "under test. Wire paths verified empirically from the SDK 1.0.2 recorder. Customer reference is the",
  "//4": "authenticated username (admin@microsoft.com) so the integration's ownership check resolves.",

  "fixtures": {
    "productsList": [
      { "product": { "id": 700001, "name": "Pro Plan", "handle": "pro-plan", "description": "", "price_in_cents": 29900, "interval": 1, "interval_unit": "month", "require_credit_card": false, "product_family": { "id": 600001, "handle": "eshop-plans" } } },
      { "product": { "id": 700002, "name": "Basic Plan", "handle": "basic-plan", "description": "", "price_in_cents": 2900, "interval": 1, "interval_unit": "month", "require_credit_card": false, "product_family": { "id": 600001, "handle": "eshop-plans" } } }
    ],
    "productProByHandle":   { "product": { "id": 700001, "name": "Pro Plan", "handle": "pro-plan", "price_in_cents": 29900, "interval": 1, "interval_unit": "month", "require_credit_card": false, "product_family": { "id": 600001, "handle": "eshop-plans" } } },
    "productBasicByHandle": { "product": { "id": 700002, "name": "Basic Plan", "handle": "basic-plan", "price_in_cents": 2900, "interval": 1, "interval_unit": "month", "require_credit_card": false, "product_family": { "id": 600001, "handle": "eshop-plans" } } },

    "knownCustomer": { "customer": { "id": 900001, "first_name": "Admin", "last_name": "Customer", "email": "admin@microsoft.com", "reference": "admin@microsoft.com", "organization": null, "created_at": "2026-01-01T00:00:00-05:00" } },
    "createdCustomer": { "customer": { "id": 900002, "first_name": "{{body.customer.first_name}}", "last_name": "{{body.customer.last_name}}", "email": "{{body.customer.email}}", "reference": "{{body.customer.reference}}", "created_at": "2026-01-01T00:00:00-05:00" } },

    "site": { "site": { "id": 1, "subdomain": "acme", "name": "eShop Sandbox", "relationship_invoicing_enabled": false, "currency": "USD" } },

    "activeSub":  { "subscription": { "id": 950001, "state": "active",   "balance_in_cents": 0, "product_price_in_cents": 29900, "currency": "USD", "cancel_at_end_of_period": false, "current_period_ends_at": "2026-02-01T00:00:00-05:00", "product_version_number": 1, "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "onHoldSub":  { "subscription": { "id": 950002, "state": "on_hold",  "balance_in_cents": 0, "currency": "USD", "on_hold_at": "2026-01-10T00:00:00-05:00", "cancel_at_end_of_period": false, "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "canceledSub":{ "subscription": { "id": 950003, "state": "canceled", "balance_in_cents": 0, "currency": "USD", "canceled_at": "2026-01-15T00:00:00-05:00", "cancellation_method": "merchant_api", "cancel_at_end_of_period": false, "product": { "id": 700002, "handle": "basic-plan", "name": "Basic Plan", "price_in_cents": 2900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },

    "listSubs": [ { "subscription": { "id": 950003, "state": "canceled", "cancel_at_end_of_period": false, "product": { "id": 700002, "handle": "basic-plan", "name": "Basic Plan" }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } } ],

    "holdResult":       { "subscription": { "id": "{{path.sid}}", "state": "on_hold",  "cancel_at_end_of_period": false, "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "resumeResult":     { "subscription": { "id": "{{path.sid}}", "state": "active",   "cancel_at_end_of_period": false, "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "reactivateResult": { "subscription": { "id": "{{path.sid}}", "state": "active",   "cancel_at_end_of_period": false, "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "cancelResult":     { "subscription": { "id": "{{path.sid}}", "state": "canceled", "cancel_at_end_of_period": false, "canceled_at": "2026-01-15T00:00:00-05:00", "cancellation_method": "merchant_api", "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "delayedCancelResult": { "subscription": { "id": "{{path.sid}}", "state": "active", "cancel_at_end_of_period": true, "current_period_ends_at": "2026-02-01T00:00:00-05:00", "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "updateResult":     { "subscription": { "id": "{{path.sid}}", "state": "active", "cancel_at_end_of_period": false, "product": { "id": 700002, "handle": "basic-plan", "name": "Basic Plan", "price_in_cents": 2900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "createdSub":       { "subscription": { "id": 950010, "state": "active", "cancel_at_end_of_period": false, "product": { "id": 700001, "handle": "pro-plan", "name": "Pro Plan", "price_in_cents": 29900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "migrationResult":  { "subscription": { "id": "{{path.sid}}", "state": "active", "cancel_at_end_of_period": false, "product": { "id": 700002, "handle": "basic-plan", "name": "Basic Plan", "price_in_cents": 2900 }, "customer": { "id": 900001, "reference": "admin@microsoft.com" } } },
    "migrationPreview": { "migration": { "prorated_adjustment_in_cents": 0, "charge_in_cents": 2900, "payment_due_in_cents": 0, "credit_applied_in_cents": 0 } },

    "usageResult": { "usage": { "id": 990001, "memo": "{{body.usage.memo}}", "quantity": "{{body.usage.quantity}}", "component_id": 800001, "component_handle": "api-calls", "subscription_id": "{{path.sid}}", "created_at": "2026-01-20T00:00:00-05:00" } },
    "subComponentRead": { "component": { "id": 800001, "component_id": 800001, "subscription_id": "{{path.sid}}", "name": "API Calls", "kind": "metered_component", "unit_name": "call", "unit_balance": 5, "enabled": true, "component_handle": "api-calls" } },

    "componentMetered": { "component": { "id": 800001, "name": "API Calls", "handle": "api-calls", "kind": "metered_component", "unit_name": "call", "pricing_scheme": "per_unit", "product_family_id": 600001 } },

    "pfNotFound": "A valid product_family_id is required"
  },

  "routes": [
    { "method": "GET", "path": "/product_families/{pfId}/products.json", "cases": [
      { "when": { "pathIn": { "pfId": ["600001"] } }, "status": 200, "bodyFixture": "productsList" },
      { "status": 404, "bodyFixture": "pfNotFound" }
    ] },

    { "method": "GET", "path": "/products/handle/{handle}.json", "cases": [
      { "when": { "pathIn": { "handle": ["pro-plan"] } }, "status": 200, "bodyFixture": "productProByHandle" },
      { "when": { "pathIn": { "handle": ["basic-plan"] } }, "status": 200, "bodyFixture": "productBasicByHandle" },
      { "status": 404, "body": { "errors": ["Product not found"] } }
    ] },

    { "method": "GET", "path": "/site.json", "cases": [
      { "status": 200, "bodyFixture": "site" }
    ] },

    { "method": "GET", "path": "/components/lookup.json", "cases": [
      { "when": { "queryIn": { "handle": ["api-calls"] } }, "status": 200, "bodyFixture": "componentMetered" },
      { "status": 404 }
    ] },

    { "method": "POST", "path": "/customers.json", "cases": [
      { "when": { "bodyMissing": ["customer.email", "customer.first_name", "customer.last_name"] }, "status": 422, "body": { "errors": ["First name: cannot be blank.", "Last name: cannot be blank.", "Email: cannot be blank."] } },
      { "status": 200, "bodyFixture": "createdCustomer" }
    ] },

    { "method": "GET", "path": "/customers/lookup.json", "cases": [
      { "when": { "queryIn": { "reference": ["admin@microsoft.com"] } }, "status": 200, "bodyFixture": "knownCustomer" },
      { "status": 404 }
    ] },

    { "method": "GET", "path": "/customers/{customerId}/subscriptions.json", "cases": [
      { "when": { "pathIn": { "customerId": ["900001"] } }, "status": 200, "bodyFixture": "listSubs" },
      { "status": 404 }
    ] },

    { "method": "GET", "path": "/subscriptions/{sid}.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001"] } }, "status": 200, "bodyFixture": "activeSub" },
      { "when": { "pathIn": { "sid": ["950002"] } }, "status": 200, "bodyFixture": "onHoldSub" },
      { "when": { "pathIn": { "sid": ["950003"] } }, "status": 200, "bodyFixture": "canceledSub" },
      { "status": 404 }
    ] },

    { "method": "POST", "path": "/subscriptions/{sid}/hold.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001"] } }, "status": 200, "bodyFixture": "holdResult" },
      { "status": 422, "body": { "errors": ["This subscription is not eligible to be put on hold."] } }
    ] },

    { "method": "POST", "path": "/subscriptions/{sid}/resume.json", "cases": [
      { "when": { "pathIn": { "sid": ["950002"] } }, "status": 200, "bodyFixture": "resumeResult" },
      { "status": 422, "body": { "errors": ["Only subscriptions that are on hold can be resumed."] } }
    ] },

    { "method": "PUT", "path": "/subscriptions/{sid}/reactivate.json", "cases": [
      { "when": { "pathIn": { "sid": ["950003"] } }, "status": 200, "bodyFixture": "reactivateResult" },
      { "status": 422, "body": { "errors": ["Cannot reactivate a subscription that is not canceled."] } }
    ] },

    { "method": "POST", "path": "/subscriptions/{sid}/delayed_cancel.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001", "950002"] } }, "status": 200, "bodyFixture": "delayedCancelResult" },
      { "status": 404 }
    ] },

    { "method": "PUT", "path": "/subscriptions/{sid}.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001", "950002", "950003"] } }, "status": 200, "bodyFixture": "updateResult" },
      { "status": 404 }
    ] },

    { "method": "POST", "path": "/subscriptions.json", "cases": [
      { "when": { "bodyMissing": ["subscription"] }, "status": 422, "body": { "errors": ["Subscription: cannot be blank."] } },
      { "when": { "bodyValueNotIn": { "subscription.product_handle": ["pro-plan", "basic-plan"] } }, "status": 422, "body": { "errors": ["Product: could not be found."] } },
      { "status": 201, "bodyFixture": "createdSub" }
    ] },

    { "method": "POST", "path": "/subscriptions/{sid}/migrations/preview.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001", "950002", "950003"] } }, "status": 200, "bodyFixture": "migrationPreview" },
      { "status": 404 }
    ] },

    { "method": "POST", "path": "/subscriptions/{sid}/migrations.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001", "950002", "950003"] } }, "status": 200, "bodyFixture": "migrationResult" },
      { "status": 404 }
    ] },

    { "method": "DELETE", "path": "/subscriptions/{sid}.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001", "950002"] } }, "status": 200, "bodyFixture": "cancelResult" },
      { "status": 404 }
    ] },

    { "method": "GET", "path": "/subscriptions/{sid}/components/{cid}.json", "cases": [
      { "when": { "pathIn": { "sid": ["950001", "950002", "950003"], "cid": ["800001"] } }, "status": 200, "bodyFixture": "subComponentRead" },
      { "status": 404 }
    ] },

    { "method": "POST", "path": "/subscriptions/{sid}/components/{cid}/usages.json", "cases": [
      { "when": { "pathIn": { "cid": ["800001"] }, "bodyPresent": ["usage"] }, "status": 200, "bodyFixture": "usageResult" },
      { "status": 422, "body": { "errors": ["Usage: cannot be blank."] } }
    ] }
  ]
}
