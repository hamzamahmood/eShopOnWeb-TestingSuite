<?xml version="1.0" encoding="utf-8"?>
<!--
  Run settings for the black-box suite. Rider: Settings > Build, Execution, Deployment > Unit Testing >
  Test Runner > "Use specific .runsettings file" and point it here (or right-click the file > "Use as
  runsettings"). This sets the base URL of the PublicApi under test for the whole run — change it to target
  the Direct instance, a different port, etc. Everything here is optional; the tests default to
  https://localhost:5099 when no env var is set.
-->
<RunSettings>
  <RunConfiguration>
    <EnvironmentVariables>
      <PUBLICAPI_BASEURL>https://localhost:5099</PUBLICAPI_BASEURL>
      <!-- Optional overrides (defaults match the Maxio mock server):
      <KNOWN_CUSTOMER_REFERENCE>cust_12345</KNOWN_CUSTOMER_REFERENCE>
      <KNOWN_CUSTOMER_ID>98765</KNOWN_CUSTOMER_ID>
      <UNKNOWN_CUSTOMER_REFERENCE>no_such_customer_ref</UNKNOWN_CUSTOMER_REFERENCE>
      <UNKNOWN_CUSTOMER_ID>99999999</UNKNOWN_CUSTOMER_ID>
      -->
    </EnvironmentVariables>
  </RunConfiguration>
</RunSettings>
