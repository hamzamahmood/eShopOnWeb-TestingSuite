@page
@using Microsoft.eShopWeb.ApplicationCore.Entities.SubscriptionAggregate
@model Microsoft.eShopWeb.Web.Pages.Subscriptions.MineModel
@{
    ViewData["Title"] = "My Subscriptions";
    var usd = System.Globalization.CultureInfo.GetCultureInfo("en-US");
}

<div class="esh-orders">
    <div class="container">
        <h1>@ViewData["Title"]</h1>

        @if (!string.IsNullOrEmpty(Model.StatusMessage))
        {
            <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        @if (Model.Preview != null)
        {
            var preview = Model.Preview;
            <div class="alert alert-info">
                <h4>Confirm plan change</h4>
                <p>
                    Change to <strong>@preview.ToPlanHandle</strong>
                    @(preview.ApplyNow ? " now (prorated)" : " at next renewal").
                </p>
                @if (preview.ApplyNow)
                {
                    <ul>
                        <li>Prorated adjustment: @((preview.ProratedAdjustmentInCents / 100m).ToString("C", usd))</li>
                        <li>Charge: @preview.Charge.ToString("C", usd)</li>
                        <li>Credit applied: @preview.Credit.ToString("C", usd)</li>
                        <li><strong>Amount due now: @preview.AmountDue.ToString("C", usd)</strong></li>
                    </ul>
                }
                else
                {
                    <ul>
                        <li>New plan price from next period: @((preview.ChargeInCents / 100m).ToString("C", usd))</li>
                        <li>Nothing is charged now.</li>
                        @if (preview.EffectiveDate.HasValue)
                        {
                            <li>Effective: @preview.EffectiveDate.Value.ToString("g")</li>
                        }
                    </ul>
                }
                <form method="post" asp-page-handler="ChangePlan">
                    <input type="hidden" name="targetPlanHandle" value="@preview.ToPlanHandle" />
                    <input type="hidden" name="applyNow" value="@preview.ApplyNow.ToString().ToLowerInvariant()" />
                    <input type="hidden" name="confirmedAmountDueInCents" value="@preview.PaymentDueInCents" />
                    <button type="submit" class="btn btn-primary">Confirm</button>
                    <a class="btn btn-default" asp-page="/Subscriptions/Mine">Cancel</a>
                </form>
            </div>
        }

        @if (Model.Subscriptions.Count == 0)
        {
            <p>
                You have no subscriptions yet. Browse the
                <a asp-page="/Subscriptions/Plans">available plans</a> to subscribe.
            </p>
        }

        @foreach (var subscription in Model.Subscriptions)
        {
            <article class="row" style="border:1px solid #eee;padding:15px;margin-bottom:20px;">
                <div class="col-md-6">
                    <h3>@(subscription.PlanName ?? subscription.PlanHandle)</h3>
                    <p>Subscription #@subscription.Id</p>
                    <p>State: <strong>@subscription.State</strong></p>
                    @if (subscription.Price.HasValue)
                    {
                        <p>Price: @subscription.Price.Value.ToString("C", usd)</p>
                    }
                    @if (subscription.CurrentPeriodEndsAt.HasValue)
                    {
                        <p>Next billing: @subscription.CurrentPeriodEndsAt.Value.ToString("g")</p>
                    }
                    @if (subscription.CancelAtEndOfPeriod)
                    {
                        <p class="text-warning">Pending cancellation at period end@(subscription.DelayedCancelAt.HasValue ? $" ({subscription.DelayedCancelAt.Value:g})" : "").</p>
                    }
                    @if (!string.IsNullOrEmpty(subscription.NextPlanHandle))
                    {
                        <p class="text-info">Scheduled to change to '@subscription.NextPlanHandle' at renewal.</p>
                    }
                </div>

                <div class="col-md-6">
                    <div class="btn-toolbar">
                        @if (subscription.CanPause)
                        {
                            <form method="post" asp-page-handler="Lifecycle" style="display:inline-block;">
                                <input type="hidden" name="action" value="Pause" />
                                <input type="hidden" name="endOfPeriod" value="false" />
                                <button type="submit" class="btn btn-default">Pause</button>
                            </form>
                        }
                        @if (subscription.CanResume)
                        {
                            <form method="post" asp-page-handler="Lifecycle" style="display:inline-block;">
                                <input type="hidden" name="action" value="Resume" />
                                <input type="hidden" name="endOfPeriod" value="false" />
                                <button type="submit" class="btn btn-default">Resume</button>
                            </form>
                        }
                        @if (subscription.CanCancel)
                        {
                            <form method="post" asp-page-handler="Lifecycle" style="display:inline-block;">
                                <input type="hidden" name="action" value="Cancel" />
                                <input type="hidden" name="endOfPeriod" value="false" />
                                <button type="submit" class="btn btn-danger">Cancel now</button>
                            </form>
                            <form method="post" asp-page-handler="Lifecycle" style="display:inline-block;">
                                <input type="hidden" name="action" value="Cancel" />
                                <input type="hidden" name="endOfPeriod" value="true" />
                                <button type="submit" class="btn btn-warning">Cancel at period end</button>
                            </form>
                        }
                        @if (subscription.CanReactivate)
                        {
                            <form method="post" asp-page-handler="Lifecycle" style="display:inline-block;">
                                <input type="hidden" name="action" value="Reactivate" />
                                <input type="hidden" name="endOfPeriod" value="false" />
                                <button type="submit" class="btn btn-success">Reactivate</button>
                            </form>
                        }
                    </div>

                    @if (subscription.CanChangePlan)
                    {
                        var otherPlans = new List<SubscriptionPlan>();
                        foreach (var plan in Model.Plans)
                        {
                            if (!string.Equals(plan.Handle, subscription.PlanHandle, StringComparison.OrdinalIgnoreCase))
                            {
                                otherPlans.Add(plan);
                            }
                        }
                        if (otherPlans.Count > 0)
                        {
                            <hr />
                            <h4>Change plan</h4>
                            <form method="post" asp-page-handler="Preview">
                                <div class="form-group">
                                    <select name="targetPlanHandle" class="form-control">
                                        @foreach (var plan in otherPlans)
                                        {
                                            <option value="@plan.Handle">@plan.Name (@plan.Price.ToString("C", usd) / @plan.IntervalUnit)</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label><input type="radio" name="applyNow" value="true" checked /> Now (prorated)</label>
                                    <label style="margin-left:10px;"><input type="radio" name="applyNow" value="false" /> At renewal</label>
                                </div>
                                <button type="submit" class="btn btn-primary">Preview change</button>
                            </form>
                        }
                    }

                    @if (subscription.IsActive)
                    {
                        <hr />
                        <h4>Report usage (API Calls)</h4>
                        <form method="post" asp-page-handler="RecordUsage">
                            <div class="form-group">
                                <input type="number" name="quantity" min="1" value="1" class="form-control" style="width:120px;display:inline-block;" />
                                <input type="text" name="memo" placeholder="memo (optional)" class="form-control" style="width:220px;display:inline-block;" />
                            </div>
                            <button type="submit" class="btn btn-default">Record usage</button>
                        </form>
                    }
                </div>
            </article>
        }
    </div>
</div>
