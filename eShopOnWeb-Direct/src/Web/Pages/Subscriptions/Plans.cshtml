@page
@model PlansModel
@{
    ViewData["Title"] = "Subscription Plans";
}
<section class="esh-catalog-hero">
    <div class="container">
        <img class="esh-catalog-title" src="~/images/main_banner_text.png" />
    </div>
</section>

<div class="container">
    <h1>Subscription Plans</h1>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Plans.Count == 0 && string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <h3 class="esh-catalog-items row">No plans are available right now.</h3>
    }
    else
    {
        <div class="row">
            @foreach (var plan in Model.Plans)
            {
                <div class="col-md-4">
                    <div class="esh-catalog-item" style="padding: 1rem; border: 1px solid #eee; margin-bottom: 1rem;">
                        <h3>@plan.Name</h3>
                        <p>@plan.Description</p>
                        <p><strong>$ @plan.Price.ToString("N2")</strong> / @(plan.Interval > 1 ? plan.Interval + " " : "")@plan.IntervalUnit</p>
                        <form method="post" asp-page-handler="Subscribe">
                            <input type="hidden" name="productHandle" value="@plan.Handle" />
                            <button type="submit" class="btn esh-basket-checkout">[ Subscribe ]</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }

    <section class="esh-basket-item">
        <a asp-page="./Mine" class="btn esh-basket-checkout text-white">[ My subscriptions ]</a>
    </section>
</div>
