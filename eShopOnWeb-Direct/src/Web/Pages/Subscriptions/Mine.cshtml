@page
@using Microsoft.eShopWeb.ApplicationCore.Entities.SubscriptionAggregate
@model MineModel
@{
    ViewData["Title"] = "My Subscriptions";
}
<div class="container">
    <h1>My Subscriptions</h1>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Subscriptions.Count == 0)
    {
        <h3 class="esh-catalog-items row">You have no subscriptions yet.</h3>
        <section class="esh-basket-item">
            <a asp-page="./Plans" class="btn esh-basket-checkout text-white">[ Browse plans ]</a>
        </section>
    }
    else
    {
        foreach (var sub in Model.Subscriptions)
        {
            <article style="border: 1px solid #eee; padding: 1rem; margin-bottom: 1.5rem;">
                <h3>@sub.ProductName <small>(@sub.State)</small></h3>
                <p>
                    <strong>$ @sub.ProductPrice.ToString("N2")</strong> / @(sub.Interval > 1 ? sub.Interval + " " : "")@sub.IntervalUnit
                    @if (sub.CurrentPeriodEndsAt.HasValue)
                    {
                        <span> &middot; Next billing: @sub.CurrentPeriodEndsAt.Value.ToString("d")</span>
                    }
                </p>
                @if (sub.CancelAtEndOfPeriod)
                {
                    <p class="text-danger">Scheduled to cancel at the end of the current period@(sub.DelayedCancelAt.HasValue ? " (" + sub.DelayedCancelAt.Value.ToString("d") + ")" : "").</p>
                }
                @if (sub.State == SubscriptionState.OnHold && sub.AutomaticallyResumeAt.HasValue)
                {
                    <p>Automatically resumes on @sub.AutomaticallyResumeAt.Value.ToString("d").</p>
                }

                <hr />

                <!-- UC2: record pay-as-you-go usage -->
                <div class="row">
                    <div class="col-md-6">
                        <h4>Record usage (pay-as-you-go)</h4>
                        <form method="post" asp-page-handler="RecordUsage" class="form-inline">
                            <input type="hidden" name="subscriptionId" value="@sub.Id" />
                            <input type="number" name="quantity" min="1" value="1" class="form-control" style="width: 6rem;" />
                            <input type="text" name="memo" placeholder="memo (optional)" class="form-control" />
                            <button type="submit" class="btn esh-basket-checkout">[ Record ]</button>
                        </form>
                    </div>

                    <!-- UC4: lifecycle -->
                    <div class="col-md-6">
                        <h4>Manage</h4>
                        <form method="post" asp-page-handler="Lifecycle" class="form-inline">
                            <input type="hidden" name="subscriptionId" value="@sub.Id" />
                            <input type="text" name="reason" placeholder="reason (optional)" class="form-control" />
                            <button type="submit" name="action" value="Pause" class="btn esh-basket-checkout">[ Pause ]</button>
                            <button type="submit" name="action" value="Resume" class="btn esh-basket-checkout">[ Resume ]</button>
                            <button type="submit" name="action" value="CancelAtEndOfPeriod" class="btn esh-basket-checkout">[ Cancel at period end ]</button>
                            <button type="submit" name="action" value="Cancel" class="btn esh-basket-checkout">[ Cancel now ]</button>
                            <button type="submit" name="action" value="Reactivate" class="btn esh-basket-checkout">[ Reactivate ]</button>
                        </form>
                    </div>
                </div>

                <hr />

                <!-- UC3: plan change with proration preview -->
                <h4>Change plan</h4>
                @{
                    var targets = new List<SubscriptionPlan>();
                    foreach (var p in Model.Plans)
                    {
                        if (!string.Equals(p.Handle, sub.ProductHandle, StringComparison.OrdinalIgnoreCase))
                        {
                            targets.Add(p);
                        }
                    }
                }
                @if (targets.Count == 0)
                {
                    <p>No alternative plans are available.</p>
                }
                else
                {
                    <form method="post" asp-page-handler="PreviewPlanChange" class="form-inline">
                        <input type="hidden" name="subscriptionId" value="@sub.Id" />
                        <select name="targetProductHandle" class="form-control">
                            @foreach (var p in targets)
                            {
                                <option value="@p.Handle">@p.Name ($@p.Price.ToString("N2")/@p.IntervalUnit)</option>
                            }
                        </select>
                        <select name="timing" class="form-control">
                            <option value="Immediate">Now (prorated)</option>
                            <option value="AtRenewal">At next renewal (no proration)</option>
                        </select>
                        <button type="submit" class="btn esh-basket-checkout">[ Preview ]</button>
                    </form>

                    @if (Model.Preview is not null && Model.PreviewSubscriptionId == sub.Id)
                    {
                        <div class="alert alert-info" style="margin-top: 1rem;">
                            <p>
                                <strong>Preview — move to @Model.PreviewTargetHandle (@Model.PreviewTiming):</strong>
                            </p>
                            @if (Model.PreviewTiming == PlanChangeTiming.AtRenewal)
                            {
                                <p>No charge now. The new plan price takes effect at your next renewal.</p>
                            }
                            else
                            {
                                <ul>
                                    <li>Prorated adjustment: $ @Model.Preview.ProratedAdjustment.ToString("N2")</li>
                                    <li>Charge: $ @Model.Preview.Charge.ToString("N2")</li>
                                    <li>Credit applied: $ @Model.Preview.CreditApplied.ToString("N2")</li>
                                    <li>Payment due now: $ @Model.Preview.PaymentDue.ToString("N2")</li>
                                </ul>
                            }
                            <form method="post" asp-page-handler="ChangePlan">
                                <input type="hidden" name="subscriptionId" value="@sub.Id" />
                                <input type="hidden" name="targetProductHandle" value="@Model.PreviewTargetHandle" />
                                <input type="hidden" name="timing" value="@Model.PreviewTiming" />
                                <input type="hidden" name="proratedAdjustmentInCents" value="@Model.Preview.ProratedAdjustmentInCents" />
                                <input type="hidden" name="chargeInCents" value="@Model.Preview.ChargeInCents" />
                                <input type="hidden" name="paymentDueInCents" value="@Model.Preview.PaymentDueInCents" />
                                <input type="hidden" name="creditAppliedInCents" value="@Model.Preview.CreditAppliedInCents" />
                                <button type="submit" class="btn esh-basket-checkout">[ Confirm plan change ]</button>
                            </form>
                        </div>
                    }
                }
            </article>
        }
    }

    <section class="esh-basket-item">
        <a asp-page="./Plans" class="btn esh-basket-checkout text-white">[ Browse plans ]</a>
    </section>
</div>
